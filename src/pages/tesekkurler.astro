---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Teşekkür Ederiz | Tabib Göz Kliniği">
    <main class="thank-you-page">
        <section class="thank-you-content glass">
            <div class="success-icon">✓</div>
            <h1>Teşekkür Ederiz!</h1>
            <p>
                Başvurunuz başarıyla alınmıştır. Uzmanlarımız en kısa sürede
                sizinle iletişime geçeceklerdir.
            </p>
            <div class="actions">
                <a href="/" class="cta-button">Ana Sayfaya Dön</a>
                <a href="/tedaviler" class="cta-button outline"
                    >Tedavilerimizi İnceleyin</a
                >
            </div>
        </section>
    </main>
</Layout>

<style>
    .thank-you-page {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: linear-gradient(135deg, #f8fbff 0%, #eef5ff 100%);
    }

    .thank-you-content {
        max-width: 600px;
        width: 100%;
        padding: 4rem 2rem;
        text-align: center;
        border-radius: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: #e7f3ef;
        color: #2e7d32;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 10px 20px rgba(46, 125, 50, 0.1);
    }

    h1 {
        font-size: 2.5rem;
        color: var(--primary-blue);
        margin: 0;
    }

    p {
        font-size: 1.1rem;
        color: #666;
        line-height: 1.6;
        max-width: 450px;
    }

    .actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
    }

    .cta-button.outline {
        background: transparent;
        color: var(--primary-blue);
        border: 1px solid var(--primary-blue);
    }

    .cta-button.outline:hover {
        background: rgba(0, 86, 179, 0.05);
    }

    @media (max-width: 640px) {
        .actions {
            flex-direction: column;
            width: 100%;
        }

        .cta-button {
            width: 100%;
        }

        h1 {
            font-size: 2rem;
        }
    }
</style>
