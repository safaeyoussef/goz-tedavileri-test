---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { news } from "../data/news";
import { Clock, Calendar, User } from "lucide-react";
---

<Layout
    title="Son Haberler | Göz Sağlığı ve Teknoloji"
    description="Göz sağlığı, cerrahi teknolojiler ve klinikten en son haberleri magazine formatında takip edin."
>
    <Header />

    <main class="news-magazine">
        <div class="container">
            <!-- Section 1: Hero & Trending -->
            <div class="magazine-hero-grid">
                <div class="hero-main">
                    <a
                        href={`/son-haberler/${news[0].slug}`}
                        class="hero-card-link"
                    >
                        <article class="hero-card">
                            <div class="hero-image">
                                <img src={news[0].image} alt={news[0].title} />
                                <span class="category-tag"
                                    >{news[0].category}</span
                                >
                            </div>
                            <div class="hero-overlay">
                                <div class="meta">
                                    <span>{news[0].date}</span>
                                    <span class="dot">•</span>
                                    <span>{news[0].readTime}</span>
                                </div>
                                <h1>{news[0].title}</h1>
                            </div>
                        </article>
                    </a>
                </div>
                <div class="hero-trending">
                    <h2 class="section-label">GÜNDEM</h2>
                    <div class="trending-list">
                        {
                            news.slice(1, 4).map((item) => (
                                <a
                                    href={`/son-haberler/${item.slug}`}
                                    class="trending-item-link"
                                >
                                    <article class="trending-item">
                                        <div class="trending-thumb">
                                            <img
                                                src={item.image}
                                                alt={item.title}
                                            />
                                        </div>
                                        <div class="trending-content">
                                            <span class="category-small">
                                                {item.category}
                                            </span>
                                            <span class="date-small">
                                                {item.date}
                                            </span>
                                            <h3>{item.title}</h3>
                                        </div>
                                    </article>
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Section 2: Overlay Row -->
            <div class="magazine-overlay-grid">
                {
                    news.slice(4, 7).map((item) => (
                        <a
                            href={`/son-haberler/${item.slug}`}
                            class="overlay-card-link"
                        >
                            <article class="overlay-card">
                                <div class="overlay-image">
                                    <img src={item.image} alt={item.title} />
                                    <span class="category-tag">
                                        {item.category}
                                    </span>
                                </div>
                                <div class="overlay-text">
                                    <span class="date-small">{item.date}</span>
                                    <h3>{item.title}</h3>
                                </div>
                            </article>
                        </a>
                    ))
                }
            </div>

            <!-- Section 3: Recent Posts -->
            <div class="recent-posts-header">
                <h2>SON YAZILAR</h2>
                <div class="filters">
                    <button class="filter-btn active" data-filter="all"
                        >All</button
                    >
                    <button class="filter-btn" data-filter="teknoloji"
                        >Teknoloji</button
                    >
                    <button class="filter-btn" data-filter="cerrahi"
                        >Cerrahi</button
                    >
                    <button class="filter-btn" data-filter="sağlık"
                        >Sağlık</button
                    >
                </div>
            </div>

            <div class="recent-posts-grid" id="recent-posts-grid">
                {
                    news.map((item) => (
                        <a
                            href={`/son-haberler/${item.slug}`}
                            class="recent-card-link"
                            data-category={item.category.toLowerCase()}
                        >
                            <article class="recent-card">
                                <div class="recent-image">
                                    <img src={item.image} alt={item.title} />
                                </div>
                                <div class="recent-content">
                                    <h3>{item.title}</h3>
                                    <span class="date-small">{item.date}</span>
                                </div>
                            </article>
                        </a>
                    ))
                }
            </div>

            <script>
                const filterBtns =
                    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
                const cards = document.querySelectorAll<HTMLElement>(
                    ".recent-card-link[data-category]",
                );

                filterBtns.forEach((btn) => {
                    btn.addEventListener("click", () => {
                        filterBtns.forEach((b) => b.classList.remove("active"));
                        btn.classList.add("active");

                        const filter = btn.dataset.filter ?? "all";

                        cards.forEach((card) => {
                            const cat = card.dataset.category ?? "";
                            if (filter === "all" || cat.includes(filter)) {
                                card.style.display = "";
                            } else {
                                card.style.display = "none";
                            }
                        });
                    });
                });
            </script>
        </div>
    </main>

    <Footer />
    <WhatsAppButton />
</Layout>

<style is:global>
    html,
    body {
        background-color: #ffffff !important;
    }

    .news-magazine {
        padding: 4rem 0 6rem;
        background-color: #ffffff;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Hero Grid */
    .magazine-hero-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .hero-card {
        position: relative;
        height: 500px;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
    }

    .hero-image {
        width: 100%;
        height: 100%;
    }

    .hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .hero-card:hover .hero-image img {
        transform: scale(1.05);
    }

    .hero-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 3rem 2rem 2rem;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
        color: white;
    }

    .hero-overlay h1 {
        font-size: 2.2rem;
        font-weight: 700;
        line-height: 1.2;
        margin-top: 0.5rem;
        color: white;
    }

    .category-tag {
        position: absolute;
        top: 1.5rem;
        left: 1.5rem;
        background: var(--primary-blue);
        color: white;
        padding: 0.3rem 0.8rem;
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 4px;
        letter-spacing: 0.5px;
    }

    .meta {
        font-size: 0.85rem;
        color: white;
        opacity: 0.9;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Trending List */
    .section-label {
        font-size: 1rem;
        font-weight: 800;
        color: var(--black);
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 3px solid var(--black);
        display: inline-block;
    }

    .trending-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .trending-item {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .trending-thumb {
        width: 100px;
        height: 80px;
        flex-shrink: 0;
        border-radius: 8px;
        overflow: hidden;
    }

    .trending-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .trending-content h3 {
        font-size: 0.95rem;
        line-height: 1.3;
        color: #0056b3;
        margin-top: 0.3rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .category-small {
        color: var(--primary-blue);
        font-size: 0.7rem;
        font-weight: 800;
        margin-right: 0.8rem;
    }

    .date-small {
        font-size: 0.75rem;
        color: #00c853;
    }

    /* Adjust trending item background for white text readability */
    .trending-item {
        background: rgba(0, 0, 0, 0.05);
        padding: 0.5rem;
        border-radius: 10px;
        transition: background 0.3s ease;
    }

    .trending-item:hover {
        background: rgba(0, 0, 0, 0.1);
    }

    /* Overlay Grid */
    .magazine-overlay-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 4rem;
    }

    .overlay-card {
        position: relative;
        height: 300px;
        border-radius: 12px;
        overflow: hidden;
    }

    .overlay-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .overlay-text {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem 1.5rem 1.5rem;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
        color: white;
    }

    .overlay-text h3 {
        font-size: 1.15rem;
        margin-top: 0.4rem;
        line-height: 1.3;
        color: white;
    }

    .overlay-text .date-small {
        color: rgba(255, 255, 255, 0.85);
    }

    /* Recent Posts */
    .recent-posts-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 1rem;
    }

    .recent-posts-header h2 {
        font-size: 1.2rem;
        font-weight: 800;
    }

    .filters {
        display: flex;
        gap: 2rem;
    }

    .filters button {
        background: none;
        border: none;
        font-weight: 600;
        font-size: 0.9rem;
        color: #999;
        cursor: pointer;
    }

    .filters button.active {
        color: var(--black);
    }

    .recent-posts-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
    }

    .recent-card h3 {
        font-size: 1rem;
        margin: 1rem 0 0.5rem;
        line-height: 1.4;
        color: #0056b3;
    }

    .recent-card {
        background: rgba(0, 0, 0, 0.05);
        padding: 1rem;
        border-radius: 16px;
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .recent-card-link {
        display: flex;
        flex-direction: column;
    }

    .recent-card:hover {
        transform: translateY(-5px);
        background: rgba(0, 0, 0, 0.08);
    }

    .recent-image {
        height: 200px;
        border-radius: 12px;
        overflow: hidden;
    }

    .recent-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .recent-content {
        padding: 0.5rem 0.25rem;
    }

    @media (max-width: 1024px) {
        .magazine-hero-grid {
            grid-template-columns: 1fr;
        }
        .recent-posts-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .magazine-overlay-grid {
            grid-template-columns: 1fr;
        }
        .filters {
            display: none;
        }
    }
</style>
