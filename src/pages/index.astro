---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import TreatmentCard from "../components/TreatmentCard.astro";
import { treatments } from "../data/treatments";
import { news } from "../data/news";
import {
	ChevronRight,
	ArrowRight,
	ShieldCheck,
	Award,
	HeartPulse,
} from "lucide-react";

const featuredTreatments = treatments.slice(0, 6);
---

<Layout title="Ana Sayfa | Modern Göz Tedavileri Rehberi">
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="container hero-content">
				<div class="hero-text fade-in">
					<span class="badge">İzmir'in Uzman Göz Merkezi</span>
					<h1>Göz Sağlığınızı Geleceğe Taşıyın</h1>
					<p>
						SMILE, LASIK ve Akıllı Mercek tedavilerinde son
						teknoloji ile tanışın. Net bir görüş, mutlu bir gelecek
						için buradayız.
					</p>
					<div class="hero-actions">
						<a href="/tedaviler" class="cta-button"
							>Tedavileri Keşfedin</a
						>
						<a href="/iletisim" class="secondary-button"
							>Ücretsiz Danışma <ChevronRight size={18} /></a
						>
					</div>
				</div>
				<div class="hero-image fade-in">
					<div class="image-wrapper">
						<img
							src="/images/hero-section.jpg"
							alt="Modern Göz Kliniği"
						/>
						<div class="stats-card glass">
							<Award className="icon" />
							<div>
								<strong>15+ Yıl</strong>
								<span>Klinik Deneyim</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Goals / Mission Section -->
		<section class="goals">
			<div class="container">
				<div class="section-header center">
					<h2>Misyonumuz ve Hedeflerimiz</h2>
					<p>
						İzmir'den dünyaya, göz sağlığı eğitiminde ve tedavisinde
						mükemmelliği hedefliyoruz.
					</p>
				</div>
				<div class="goals-grid">
					<div class="goal-item">
						<ShieldCheck size={40} className="goal-icon" />
						<h3>Güvenilir Teknoloji</h3>
						<p>
							Sadece FDA onaylı, dünya standartlarında lazer ve
							cerrahi ekipmanlar kullanıyoruz.
						</p>
					</div>
					<div class="goal-item">
						<HeartPulse size={40} className="goal-icon" />
						<h3>Kişiye Özel Tedavi</h3>
						<p>
							Her göz yapısı eşsizdir. Tedavi planımızı tamamen
							sizin biyolojik yapınıza göre şekillendiriyoruz.
						</p>
					</div>
					<div class="goal-item">
						<Award size={40} className="goal-icon" />
						<h3>Eğitim Odaklılık</h3>
						<p>
							Hastalarımızı tedavi süreçleri hakkında detaylı
							bilgilendirerek farkındalık yaratıyoruz.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Treatments Grid -->
		<section class="treatments-grid-section">
			<div class="container">
				<div class="section-header center">
					<h2>Popüler Tedavilerimiz</h2>
					<p>En çok tercih edilen 21 farklı göz tedavi yöntemi.</p>
				</div>
				<div class="treatments-grid">
					{
						featuredTreatments.map((item) => (
							<TreatmentCard
								title={item.title}
								description={item.description}
								href={`/tedaviler/${item.slug}`}
							/>
						))
					}
				</div>
				<div class="view-all-container">
					<a href="/tedaviler" class="cta-button"
						>Tüm Tedavileri Gör <ArrowRight size={18} /></a
					>
				</div>
			</div>
		</section>

		<!-- Latest Updates / News -->
		<section class="news-section">
			<div class="container">
				<div class="section-header center">
					<h2>Göz Sağlığında Güncel Gelişmeler</h2>
					<p>Teknoloji, eğitim ve klinikten en son haberler.</p>
				</div>
				<div class="news-grid">
					{
						news.slice(0, 3).map((item) => (
							<article class="news-card">
								<div class="news-image">
									<img src={item.image} alt={item.title} />
									<span class="news-category">
										{item.category}
									</span>
								</div>
								<div class="news-content">
									<span class="news-meta">
										{item.date} • {item.readTime} Okuma
									</span>
									<h3>{item.title}</h3>
									<p>{item.excerpt}</p>
									<a
										href={`/son-haberler/${item.slug}`}
										class="read-more"
									>
										Devamını Oku
									</a>
								</div>
							</article>
						))
					}
				</div>
				<div class="view-all-container">
					<a href="/guncel-haberler" class="cta-button"
						>Tüm Haberleri Gör <ArrowRight size={18} /></a
					>
				</div>
			</div>
		</section>
	</main>

	<Footer />
	<WhatsAppButton />
</Layout>

<style>
	/* Hero Styles */
	.hero {
		padding: 8rem 0 4rem;
		background: linear-gradient(
			135deg,
			var(--secondary-blue) 0%,
			#ffffff 100%
		);
		overflow: hidden;
	}

	.hero-content {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		align-items: center;
		gap: 4rem;
	}

	.badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: rgba(0, 86, 179, 0.1);
		color: var(--primary-blue);
		border-radius: 50px;
		font-weight: 600;
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
	}

	.gradient-text {
		background: linear-gradient(
			90deg,
			var(--primary-blue),
			var(--accent-green)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.hero-text h1 {
		margin-bottom: 1.5rem;
		line-height: 1.1;
		color: #0056b3;
	}

	.hero-text p {
		font-size: 1.2rem;
		color: #555;
		margin-bottom: 2.5rem;
		max-width: 500px;
	}

	.hero-actions {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}

	.secondary-button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 600;
		color: var(--primary-blue);
	}

	.hero-image {
		position: relative;
	}

	.image-wrapper {
		position: relative;
		border-radius: 20px;
		overflow: visible;
	}

	.image-wrapper img {
		width: 100%;
		height: auto;
		border-radius: 20px;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
	}

	.stats-card {
		position: absolute;
		bottom: -20px;
		left: -20px;
		padding: 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		border-radius: 12px;
	}

	.stats-card .icon {
		color: var(--accent-green);
		width: 32px;
		height: 32px;
	}

	.stats-card div {
		display: flex;
		flex-direction: column;
	}

	/* Section Commons */
	section {
		padding: 6rem 0;
	}

	.view-all-container {
		margin-top: 3rem;
		display: flex;
		justify-content: center;
	}

	.view-all-container .cta-button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background-color: var(--primary-blue);
	}

	/* Goals Styles */
	.goals {
		background-color: var(--white);
	}

	.goals-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.goal-item {
		text-align: center;
		padding: 2rem;
		transition: var(--transition-slow);
	}

	.goal-icon {
		color: var(--accent-green);
		margin-bottom: 1.5rem;
	}

	/* Treatments Grid */
	.treatments-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.view-all {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--primary-blue);
		font-weight: 600;
	}

	/* News Styles */
	.news-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.news-card {
		background: var(--white);
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
		transition: var(--transition-slow);
	}

	.news-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
	}

	.news-image {
		position: relative;
		height: 200px;
	}

	.news-image img {
		width: 100%;
		height: 100%;
		object-fit: crop;
	}

	.news-category {
		position: absolute;
		top: 1rem;
		left: 1rem;
		background: var(--accent-green);
		color: white;
		padding: 0.3rem 0.8rem;
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 600;
	}

	.news-content {
		padding: 1.5rem;
	}

	.news-meta {
		font-size: 0.8rem;
		color: #888;
		display: block;
		margin-bottom: 0.5rem;
	}

	.news-content h3 {
		font-size: 1.2rem;
		margin-bottom: 1rem;
		line-height: 1.4;
	}

	.news-content p {
		font-size: 0.95rem;
		color: #666;
		margin-bottom: 1.5rem;
	}

	.read-more {
		color: var(--primary-blue);
		font-weight: 600;
		font-size: 0.9rem;
	}

	@media (max-width: 992px) {
		.hero-content {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-text p {
			margin: 0 auto 2.5rem;
		}
		.hero-actions {
			justify-content: center;
		}
		.goals-grid,
		.treatments-grid,
		.news-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.goals-grid,
		.treatments-grid,
		.news-grid {
			grid-template-columns: 1fr;
		}
		.hero {
			padding: 6rem 0 3rem;
		}
	}
</style>
